# copy to .env.local to override. in dev the vite proxy forwards /api to this
# target, so you usually only set this if the api runs somewhere other than
# http://localhost:8080.
VITE_API_TARGET=http://localhost:8080

# if you would rather call the api directly (no proxy), set an absolute base url
# and the client will prefix it onto every request.
# VITE_API_BASE_URL=http://localhost:8080
